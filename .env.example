# Typefully API
# 取得方法: https://typefully.com/settings/api で「Generate API Key」をクリック
# v2 キーのみ有効（v1 は 2026-06-15 廃止予定）
TYPEFULLY_API_KEY=your_api_key_here

# Typefully Social Set ID（hyui_cc 用・3種類）
# APIキー設定後、/x-run setup で自動取得する（最初は空でOK）
# または `node scripts/typefully.mjs list-social-sets` で全Social Set一覧表示

# 1. クロスポスト用（X+Threads 両方紐付け・既存）
# 用途: 日常実況・告知・ノウハウスレッドなど両プラットフォームに同時投稿
TYPEFULLY_SOCIAL_SET_ID=

# 2. X 専用（@hyui_cc のみ紐付け・2026-04-28 新設）
# 用途: 引用RT（@claudeai 等公式アカウント）・バズ宣伝リプ・X固有のセルフ引用RT
TYPEFULLY_X_ONLY_SOCIAL_SET_ID=

# 3. Threads 専用（@hyui__cc のみ紐付け・2026-04-28 新設）
# 用途: 500字フル活用の長文体験談・連続投稿（Thread-to-Lead）・Threads読み物層向け
TYPEFULLY_THREADS_ONLY_SOCIAL_SET_ID=
